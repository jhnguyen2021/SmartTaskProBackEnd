## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (Mono Auto Generated Files)
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2019/2022 cache/options directory
.vs/
# Uncomment if you have tasks that create the following folders
# .vscode/

# Rider
.idea/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build results of an ATL Project
[Dd]ebugPS/
[Rr]eleasePS/
dlldata.c

# BenchmarkDotNet Artifacts
BenchmarkDotNet.Artifacts/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# Tye
.tye/

# Visual Studio profiler
*.psess
*.vsp
*.vspx
*.sap

# Visual Studio Trace Files
*.e2e

# TFS 2012 Local Workspace
$tf/

# Guidance Automation Toolkit
*.gpState

# ReSharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# DotCover
.idea/
*.dotCover

# TeamCity
_TeamCity*

# DotTrace
*.dotTrace

# NCrunch
*.ncrunch*
.*crunch*.local.xml
nCrunchTemp_*

# Web stuff
node_modules/
wwwroot/lib/

# Others
*.swp
*.bak
*.tmp
*.temp
*.log
*.vspscc
*_i.c
*_p.c
*_h.h
*.dbmdl
*.bak*
*.sql
*.sqlite

# Sensitive files
*.env

# Mac OS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini